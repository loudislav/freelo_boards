# Copy this file to .env and fill in your values.
# Note: the variable names use a zero (0), not the letter O.

FREEL0_EMAIL=your@email.com
FREEL0_API_KEY=your_api_key_here
FREEL0_UA="DeskaHanby/1.0 (your@email.com)"

# Set to false only for local development (self-signed SSL workaround).
# Must be true (or omitted) in production.
FREEL0_SSL_VERIFY=true
